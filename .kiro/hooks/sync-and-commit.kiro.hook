{
  "version": "1.0.0",
  "enabled": true,
  "name": "Sync and Commit",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "Kiro-LPL-Library\\knowledge-base"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Sync and commit to the .git repository."
  },
  "workspaceFolderName": "Kiro-LPL-Library",
  "shortName": "sync-and-commit"
}