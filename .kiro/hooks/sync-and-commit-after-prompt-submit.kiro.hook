{
  "version": "1.0.0",
  "enabled": true,
  "name": "Sync and Commit (After Prompt Submit)",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "askAgent",
    "prompt": "If there is something to commit, sync and commit to the .git repository."
  },
  "workspaceFolderName": "Kiro-LPL-Library",
  "shortName": "sync-and-commit-after-prompt-submit"
}